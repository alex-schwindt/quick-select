{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hhtrecho-quick-select",
  "main": "src/index.js",
  "compatibility_date": "2026-05-26",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
